# HuggingFace API key for primary deepfake detection (free tier available)
# Get yours at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here

# Optional: URL of a self-hosted Deepfake-detector backend (e.g., on Render)
# If provided, it will be used as an alternative detection source.
# Deploy https://github.com/namandhakad712/Deepfake-detector to Render and set:
RENDER_SERVICE_URL=https://your-render-service.onrender.com
